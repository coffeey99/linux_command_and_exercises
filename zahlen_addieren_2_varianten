#!/bin/bash

# Prüfen, ob genau 2 Argumente übergeben wurden
if [ $# -ne 2 ]; then
    echo "Benutzung: $0 <argument1> <argument2>"
    exit 1
fi

# Argumente in Variablen speichern
arg1=$1
arg2=$2

echo "Erstes Argument: $arg1"
echo "Zweites Argument: $arg2"

# Hier kann deine Logik rein
# Beispiel: beide Argumente zusammen ausgeben
echo "Kombiniert: ${arg1}_${arg2}"

