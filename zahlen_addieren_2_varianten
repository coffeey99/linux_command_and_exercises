#!/bin/bash
 
#Fragen
echo "Gib die erste Zahl ein:"
read zahl1
 
echo "Gib die zweite Zahl ein:"
read zahl2
 
#Addition
summe=$((zahl1 + zahl2))
 
# Ergebnis anzeigen
echo "Die Summe von $zahl1 und $zahl2 ist: $summe"
